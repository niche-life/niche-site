---
import { Image } from "astro:assets";
import { getCoverImage, getArticleImage } from "../utils/data.ts";
import { formatJapaneseDate } from "../utils/date.ts";
import type { Article } from "../utils/data.ts";

interface Props {
  volumeNo: number;
  title: string;
  publishedDate: string;
  image: string;
  url?: string;
  fullPdfUrl?: string;
  articles: Article[];
}

const { volumeNo, title, publishedDate, image, url, fullPdfUrl, articles } = Astro.props;

const coverImageSrc = await getCoverImage(image);

const filteredArticles = articles;

// 各記事の画像を事前に取得
const articleImages = await Promise.all(
  filteredArticles.map((article) =>
    article.image ? getArticleImage(article.image) : Promise.resolve(undefined)
  )
);

const getArticleUrl = (url: string | undefined) => {
  if (!url) return "#";
  if (url.startsWith("https://")) return url;
  return `https://media.niche-life.com/series/${url}`;
};

const isDOI = (url: string | undefined) => {
  return url?.startsWith("https://doi.org/") ?? false;
};

const getFullPdfUrl = (url: string | undefined) => {
  if (!url) return "#";
  if (url.startsWith("https://")) return url;
  return `https://media.niche-life.com/series/${url}`;
};
---

<div class="mb-8 sm:mb-10">
  <div class="flex items-start gap-4 sm:gap-5">
    {
      coverImageSrc ? (
        <Image
          src={coverImageSrc}
          alt={`表紙 - ${title}`}
          width="180"
          height="254"
          class="shrink-0 rounded-sm border border-slate-300"
        />
      ) : (
        <div class="h-63.5 w-45 shrink-0 rounded-sm bg-slate-500 text-slate-100 flex items-center justify-center">
          <span>No Image</span>
        </div>
      )
    }
    <div class="min-w-0">
      <p class="m-0 text-sm leading-6 text-slate-600">第{volumeNo}号</p>
      <p class="m-0 text-sm leading-6 text-slate-600">
        公開日: {formatJapaneseDate(publishedDate)}
      </p>
      <p class="m-0 text-sm leading-6 text-slate-600">記事数: {filteredArticles.length}件</p>
    </div>
  </div>
</div>

<ul class="m-0 list-none p-0 space-y-3">
  {
    filteredArticles.map((article, i) => {
      const articleImg = articleImages[i];
      const href = getArticleUrl(article.url);
      return (
        <li>
          <a
            href={href}
            target="_blank"
            rel="noopener"
            class="block bg-white rounded-2xl border border-slate-200 p-5 no-underline hover:shadow-md hover:border-slate-300 transition-all duration-200"
          >
            {/* タイトル行：タイトル左・ページ番号右 */}
            <div class="flex justify-between items-start gap-3 mb-3">
              <p class="m-0 font-bold text-base leading-snug text-slate-800">
                {article.title}
              </p>
              {article.page && (
                <span class="shrink-0 text-sm font-medium text-slate-500">
                  p.{article.page}
                </span>
              )}
            </div>

            {/* 本文行：画像（任意）＋メタ情報 */}
            <div class="flex items-start gap-4">
              {articleImg && (
                <Image
                  src={articleImg}
                  alt=""
                  width="176"
                  height="120"
                  class="shrink-0 object-cover w-44 h-30"
                />
              )}
              <div class="min-w-0 space-y-0.5">
                {article.author && (
                  <p class="m-0 text-sm text-slate-600">{article.author}</p>
                )}
                {isDOI(article.url) && (
                  <p class="m-0 text-xs text-slate-400 break-all">
                    DOI: {article.url}
                  </p>
                )}
              </div>
            </div>
          </a>
        </li>
      );
    })
  }
</ul>

{fullPdfUrl && (
  <div class="mt-8 pt-6">
    <a
      href={getFullPdfUrl(fullPdfUrl)}
      class="inline-block text-(--sl-color-accent) no-underline text-base leading-7 font-semibold hover:text-(--sl-color-accent-high) hover:underline underline-offset-2"
      target="_blank"
      rel="noopener"
    >
      フルPDF（全記事まとめ）
    </a>
    <p class="m-0 text-sm leading-6 text-slate-600">
      大容量ファイルのため、ダウンロード時の通信量にご注意ください。Wi-Fi接続を推奨します。
    </p>
  </div>
)}

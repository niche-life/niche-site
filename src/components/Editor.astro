---
import { Image } from 'astro:assets';
import { getEditorImage } from '../utils/data.ts';

interface Props {
  name: string;
  img?: string;
  role: string[];
  fav?: string[];
}

const { name, img, role, fav } = Astro.props;

// 編集者画像を取得
const editorImage = await getEditorImage(img);
---

<div class="flex items-start gap-4 mb-6">
  <div class="shrink-0">
    {editorImage ? (
      <Image 
        src={editorImage} 
        alt={name} 
        width="100"
        height="100"
        class="w-24 h-24 rounded object-cover"
      />
    ) : (
      <div class="w-24 h-24 rounded bg-gray-200 flex items-center justify-center text-gray-400 text-xs">
        No Image
      </div>
    )}
  </div>
  <div class="m-0">
    <p class="font-semibold m-0">{name}</p>
    <p class="m-0">{role.join(' / ')}</p>
    {fav && <p class="m-0">専門: {fav.join(', ')}</p>}
    <div class="m-0">
      <slot />
    </div>
  </div>
</div>

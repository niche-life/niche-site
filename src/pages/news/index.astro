---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("news")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const formatJaDate = (date: Date): string =>
  `${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日`;
---

<StarlightPage frontmatter={{ title: "お知らせ" }}>
  <ul class="m-0 list-none divide-y divide-slate-200/70 p-0">
    {
      posts.map((post) => (
        <li class="py-3 sm:py-4">
          <p class="m-0 text-sm leading-6 text-slate-600">
            {formatJaDate(post.data.pubDate)}
          </p>
          {(post.body ?? "").trim().length > 0 ? (
            <a
              href={`/news/${post.id.replace(/^news\//, "")}/`}
              class="mt-0.5 inline-block text-base leading-7 text-green-700 underline-offset-2 hover:text-green-800 hover:underline"
            >
              {post.data.title}
            </a>
          ) : (
            <p class="mt-0.5 mb-0 text-base leading-7 text-slate-800">
              {post.data.title}
            </p>
          )}
        </li>
      ))
    }
  </ul>
</StarlightPage>

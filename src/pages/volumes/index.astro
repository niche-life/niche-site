---
import StarlightPage from "@astrojs/starlight/components/StarlightPage.astro";
import { Image } from "astro:assets";
import { loadAllVolumesWithImages } from "../../utils/data.ts";
import { formatJapaneseDate } from "../../utils/date.ts";

// 新しい分離データ構造で全巻データと表紙画像を一括取得
const volumesWithImages = await loadAllVolumesWithImages();
---

<StarlightPage
  frontmatter={{
    title: "バックナンバー",
    description: "ニッチェ・ライフの各バックナンバー。無料でお読みいただけます。",
  }}
>
  <ul class="m-0 list-none divide-y divide-slate-200/70 p-0">
    {
      volumesWithImages.map((volume) => (
        <li class="py-3 sm:py-4">
          <a
            href={`/volumes/${volume.no}/`}
            class="flex items-start gap-3 no-underline text-inherit"
          >
            <div class="shrink-0">
              {volume.coverImage && (
                <Image
                  src={volume.coverImage}
                  alt={`表紙 - ${volume.title}`}
                  width={56}
                  height={79}
                  class="h-[79px] w-[56px] rounded-sm object-cover ring-1 ring-slate-200"
                />
              )}
            </div>
            <div class="min-w-0 flex-1">
              <p class="m-0 text-sm leading-6 text-slate-600">
                発行日: {formatJapaneseDate(volume.publishedDate)}
              </p>
              <div class="mt-0.5 flex flex-wrap items-baseline gap-x-3 gap-y-1">
                <h3 class="m-0 text-base leading-7 font-semibold text-slate-900 hover:underline underline-offset-2">
                {volume.title}
                </h3>
                <p class="m-0 text-sm leading-6 text-slate-600">
                  記事数: {volume.articleCount}件
                </p>
              </div>
            </div>
          </a>
        </li>
      ))
    }
  </ul>
</StarlightPage>
